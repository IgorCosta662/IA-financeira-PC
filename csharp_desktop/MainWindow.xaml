<Window x:Class="FinancaAIDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FinancaAIDesktop"
        Title="Finança AI Ultimate - Desktop Edition"
        Height="720" Width="1100"
        MinWidth="950" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDark}">
    <Window.Resources>
        <local:TypeToColorConverter x:Key="TypeToColorConverter" />
        <local:TypeToValueColorConverter x:Key="TypeToValueColorConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar -->
            <ColumnDefinition Width="240" />
            <!-- Main Content Panel -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar Background/Container -->
        <Border Grid.Column="0" Background="{StaticResource BgHeader}" BorderBrush="{StaticResource BorderLight}" BorderThickness="0,0,1,0">
            <Grid Margin="16,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App Title / Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <TextBlock Text="✨ Finança AI" FontFamily="Segoe UI" FontWeight="Bold" FontSize="22" Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="Desktop Ultimate Edition" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="2,2,0,0"/>
                </StackPanel>

                <!-- Menu Options -->
                <StackPanel Grid.Row="1">
                    <Button Content="📊 Painel Geral" Click="NavDashboard_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavDashboard" Background="#1e293b" Foreground="White" Margin="0,0,0,4" />
                    <Button Content="🏦 Contas Bancárias" Click="NavAccounts_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavAccounts" Margin="0,0,0,4" />
                    <Button Content="💳 Cartões de Crédito" Click="NavCards_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavCards" Margin="0,0,0,4" />
                    <Button Content="💸 Registrar Transação" Click="NavTransactions_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavTransactions" Margin="0,0,0,4" />
                    <Button Content="📈 Investimentos" Click="NavInvestments_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavInvestments" Margin="0,0,0,4" />
                    <Button Content="💬 Consultor de IA" Click="NavChat_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavChat" Margin="0,0,0,4" />
                    <Button Content="⚙️ Configurações" Click="NavSettings_Click" Style="{StaticResource SidebarBtnStyle}" x:Name="BtnNavSettings" Margin="0,0,0,4" />
                </StackPanel>

                <!-- User Footer Badge -->
                <Border Grid.Row="2" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBlue}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="C#" Foreground="White" FontFamily="Segoe UI" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock x:Name="TxtFooterUserName" Text="Usuário C#" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="12" />
                            <TextBlock Text="Sincronizado" FontSize="10" Foreground="{StaticResource AccentGreen}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Side Main Content Panel -->
        <Grid Grid.Column="1" Margin="24">
            
            <!-- VIEW 1: DASHBOARD -->
            <Grid x:Name="ViewDashboard" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Visão Geral do Patrimônio" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Seus saldos, investimentos e metas atualizados em tempo real." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>

                <!-- Balance Summary Cards -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource AccentGreen}" BorderThickness="2,1,1,1">
                        <StackPanel>
                            <TextBlock Text="Saldo Disponível" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                            <TextBlock x:Name="TxtDashTotalBalance" Text="R$ 0,00" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,0" />
                            <TextBlock x:Name="TxtDashAccountsCount" Text="0 contas ativas" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource AccentBlue}" BorderThickness="2,1,1,1">
                        <StackPanel>
                            <TextBlock Text="Patrimônio Investido" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                            <TextBlock x:Name="TxtDashTotalInvested" Text="R$ 0,00" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,0" />
                            <TextBlock x:Name="TxtDashInvestmentsCount" Text="0 ativos cadastrados" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" BorderBrush="{StaticResource RedAccent}" BorderThickness="2,1,1,1">
                        <StackPanel>
                            <TextBlock Text="Total de Dívidas" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                            <TextBlock x:Name="TxtDashTotalDebts" Text="R$ 0,00" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,8,0,0" />
                            <TextBlock x:Name="TxtDashDebtsStatus" Text="Regular" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Columns: Left (Transactions & Goals) | Right (Active Cards & Assets) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Latest Transactions -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Últimas Transações" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,12" />
                            <ListView Grid.Row="1" x:Name="LstDashTransactions" Background="Transparent" BorderThickness="0" Foreground="White" AlternationCount="2">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6" Width="400">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="8" Height="8" CornerRadius="4" Background="{Binding Type, Converter={StaticResource TypeToColorConverter}}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Description}" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat='R$ {0:N2}'}" FontSize="13" FontWeight="Bold" Foreground="{Binding Type, Converter={StaticResource TypeToValueColorConverter}}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Right: Goals & Cards -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Goals -->
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Metas de Economia" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" />
                                <ListView Grid.Row="1" x:Name="LstDashGoals" Background="Transparent" BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,4" Width="260">
                                                <Grid>
                                                    <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                                    <TextBlock Text="{Binding CurrentAmount, StringFormat='R$ {0:N2}'}" FontSize="11" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right" />
                                                </Grid>
                                                <ProgressBar Value="{Binding CurrentAmount}" Maximum="{Binding TargetAmount}" Height="6" Background="#334155" Foreground="{StaticResource AccentGreen}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!-- Cards -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Meus Cartões" FontSize="14" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" />
                                <ListView Grid.Row="1" x:Name="LstDashCards" Background="Transparent" BorderThickness="0">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4" Width="260">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Bank}" FontSize="12" FontWeight="Bold" Foreground="White" />
                                                    <TextBlock Text="{Binding CardName}" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Limit, StringFormat='Lim: R$ {0:N2}'}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- VIEW 2: ACCOUNTS -->
            <Grid x:Name="ViewAccounts" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Contas Bancárias" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Gerencie seus saldos das carteiras e contas correntes." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <ListView x:Name="LstAccounts" Background="Transparent" BorderThickness="0" Margin="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8" Width="360">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Balance, StringFormat='R$ {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Criar Nova Conta" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12" />
                            <TextBlock Text="Nome da Conta" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewAccName" Margin="0,0,0,12" />
                            
                            <TextBlock Text="Tipo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CboNewAccType" Margin="0,0,0,12">
                                <ComboBoxItem Content="Conta Corrente" IsSelected="True" Tag="checking" />
                                <ComboBoxItem Content="Poupança / Reserva" Tag="savings" />
                                <ComboBoxItem Content="Carteira Digital" Tag="digital_wallet" />
                                <ComboBoxItem Content="Dinheiro em Mãos" Tag="cash" />
                            </ComboBox>

                            <TextBlock Text="Saldo Inicial" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewAccBalance" Text="0" Margin="0,0,0,12" />

                            <Button Content="💾 Adicionar Conta" Click="BtnAddAccount_Click" Background="{StaticResource AccentGreen}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- VIEW 3: CARDS -->
            <Grid x:Name="ViewCards" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Cartões de Crédito" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Controle suas faturas, limites e datas de fechamento." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <ListView x:Name="LstCards" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8" Width="360">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Bank}" FontSize="14" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding CardName}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Limit, StringFormat='Lim: R$ {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Adicionar Cartão" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12" />
                            
                            <TextBlock Text="Instituição/Banco" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewCardBank" Margin="0,0,0,12" />

                            <TextBlock Text="Apelido do Cartão" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewCardName" Margin="0,0,0,12" />

                            <TextBlock Text="Bandeira" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CboNewCardBrand" Margin="0,0,0,12">
                                <ComboBoxItem Content="Visa" IsSelected="True" Tag="visa" />
                                <ComboBoxItem Content="Mastercard" Tag="mastercard" />
                                <ComboBoxItem Content="Elo" Tag="elo" />
                                <ComboBoxItem Content="Amex" Tag="amex" />
                            </ComboBox>

                            <TextBlock Text="Limite Total" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewCardLimit" Text="1000" Margin="0,0,0,12" />

                            <TextBlock Text="Dia do Vencimento" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewCardDue" Text="10" Margin="0,0,0,12" />

                            <Button Content="💾 Adicionar Cartão" Click="BtnAddCard_Click" Background="{StaticResource AccentPurple}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- VIEW 4: TRANSACTIONS -->
            <Grid x:Name="ViewTransactions" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Registro de Transações" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Histórico completo de entradas, saídas e transferências de saldo." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <ListView x:Name="LstTransactions" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6" Width="400">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="13" FontWeight="SemiBold" Foreground="White" />
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='R$ {0:N2}'}" FontSize="13" FontWeight="Bold" Foreground="{Binding Type, Converter={StaticResource TypeToValueColorConverter}}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Nova Transação" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12" />

                            <TextBlock Text="Tipo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CboNewTransType" Margin="0,0,0,12">
                                <ComboBoxItem Content="Saída / Despesa" IsSelected="True" Tag="expense" />
                                <ComboBoxItem Content="Entrada / Receita" Tag="income" />
                            </ComboBox>

                            <TextBlock Text="Descrição" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewTransDesc" Margin="0,0,0,12" />

                            <TextBlock Text="Valor" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewTransAmount" Text="0.00" Margin="0,0,0,12" />

                            <TextBlock Text="Categoria" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewTransCategory" Margin="0,0,0,12" />

                            <TextBlock Text="Conta de Origem" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CboNewTransAccount" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,0,12" />

                            <Button Content="💾 Confirmar Lançamento" Click="BtnAddTransaction_Click" Background="{StaticResource AccentBlue}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- VIEW 5: INVESTMENTS -->
            <Grid x:Name="ViewInvestments" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Investimentos e Portfólio" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Monitore seus ativos financeiros e suas taxas de rendimento." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <ListView x:Name="LstInvestments" Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8" Width="360">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="White" />
                                            <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{StaticResource TextSecondary}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentAmount, StringFormat='R$ {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Adicionar Ativo" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12" />

                            <TextBlock Text="Nome do Ativo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewInvName" Margin="0,0,0,12" />

                            <TextBlock Text="Tipo de Ativo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewInvType" Margin="0,0,0,12" />

                            <TextBlock Text="Valor Investido" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewInvInvested" Text="0.00" Margin="0,0,0,12" />

                            <TextBlock Text="Valor Atualizado" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewInvCurrent" Text="0.00" Margin="0,0,0,12" />

                            <TextBlock Text="Taxa de Rendimento (% a.a.)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtNewInvRate" Text="10.00" Margin="0,0,0,12" />

                            <Button Content="💾 Gravar Ativo" Click="BtnAddInvestment_Click" Background="{StaticResource AccentBlue}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- VIEW 6: CHAT -->
            <Grid x:Name="ViewChat" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Conversar com o Assistente de IA" Style="{StaticResource HeaderTextStyle}" />
                        <TextBlock Text="Peça análises de portfólio, formas de poupar ou tire dúvidas gerais." Style="{StaticResource SubHeaderTextStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Agente:" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <ComboBox x:Name="CboChatAgent" SelectionChanged="CboChatAgent_SelectionChanged" Width="140">
                            <ComboBoxItem Content="Dr. Finança [Equilibrado]" Tag="default" IsSelected="True" />
                            <ComboBoxItem Content="Tony [Investidor]" Tag="investor" />
                            <ComboBoxItem Content="Sr. Silas [Poupador]" Tag="poupador" />
                            <ComboBoxItem Content="Sofia [Educadora]" Tag="educador" />
                            <ComboBoxItem Content="Arthur [Terapeuta]" Tag="psicologo" />
                            <ComboBoxItem Content="Nerd dos Números" Tag="nerd" />
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Conversation Panel -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                    <ScrollViewer x:Name="ScrollChat" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="LstChatBubbles" Margin="16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="12" Margin="0,8" MaxWidth="600" HorizontalAlignment="{Binding Alignment}" Background="{Binding BackgroundBrush}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Sender}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding Text}" FontSize="13" Foreground="White" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Chat Input Controls -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtChatMsg" Height="42" FontSize="13" KeyDown="TxtChatMsg_KeyDown" Padding="12,10" />
                    <Button Grid.Column="1" Content="Enviar 🚀" Click="BtnSendChat_Click" Margin="8,0,0,0" Height="42" Background="{StaticResource AccentBlue}" />
                </Grid>
            </Grid>

            <!-- VIEW 7: SETTINGS -->
            <Grid x:Name="ViewSettings" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Configurações e Chaves de IA" Style="{StaticResource HeaderTextStyle}" />
                    <TextBlock Text="Configure seu perfil, moedas e credenciais de inteligência artificial." Style="{StaticResource SubHeaderTextStyle}" />
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="600" HorizontalAlignment="Left" Margin="8">
                            
                            <TextBlock Text="Dados Gerais do Usuário" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Nome do Usuário" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                    <TextBox x:Name="TxtSettingsUser" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Moeda" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="CboSettingsCurrency">
                                        <ComboBoxItem Content="Real Brasileiro (R$)" Tag="BRL" IsSelected="True" />
                                        <ComboBoxItem Content="Dólar Americano ($)" Tag="USD" />
                                        <ComboBoxItem Content="Euro (€)" Tag="EUR" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Separator Background="{StaticResource BorderLight}" Margin="0,8,0,16" />

                            <TextBlock Text="Configurações de Provedores de IA" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,16" />
                            
                            <TextBlock Text="Provedor Ativo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="CboSettingsProvider" SelectionChanged="CboSettingsProvider_SelectionChanged" Margin="0,0,0,16">
                                <ComboBoxItem Content="Google Gemini" Tag="gemini" IsSelected="True" />
                                <ComboBoxItem Content="OpenAI (ChatGPT)" Tag="openai" />
                                <ComboBoxItem Content="NVIDIA NIM" Tag="nvidia" />
                                <ComboBoxItem Content="Customizado (Groq, DeepSeek, etc)" Tag="custom_openai" />
                            </ComboBox>

                            <TextBlock Text="Nome do Modelo" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                            <TextBox x:Name="TxtSettingsModel" Text="gemini-2.5-flash" Margin="0,0,0,16" />

                            <!-- Contextual Credentials Inputs -->
                            <StackPanel x:Name="PanelGeminiCreds" Margin="0,0,0,16">
                                <TextBlock Text="Chave de API do Gemini (Opcional)" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtSettingsGeminiKey" />
                            </StackPanel>

                            <StackPanel x:Name="PanelOpenAiCreds" Visibility="Collapsed" Margin="0,0,0,16">
                                <TextBlock Text="Chave de API da OpenAI" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtSettingsOpenAiKey" />
                            </StackPanel>

                            <StackPanel x:Name="PanelNvidiaCreds" Visibility="Collapsed" Margin="0,0,0,16">
                                <TextBlock Text="Chave de API da NVIDIA NIM" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtSettingsNvidiaKey" />
                            </StackPanel>

                            <StackPanel x:Name="PanelCustomCreds" Visibility="Collapsed">
                                <TextBlock Text="Base URL" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" />
                                <TextBox x:Name="TxtSettingsCustomBase" Margin="0,0,0,16" />
                            </StackPanel>

                            <Button Content="💾 Salvar Configurações" Click="BtnSaveSettings_Click" Background="{StaticResource AccentGreen}" Margin="0,12,0,0" Width="180" HorizontalAlignment="Left" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
